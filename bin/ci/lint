#!/usr/bin/env bash
set -euo pipefail

# Run treefmt with the formatters declared in treefmt.ci.toml. Use nix-shell
# rather than `devenv shell` so CI avoids evaluating the full devenv profile
# (same substitute-path failures as bin/ci/deadnix had on GitHub runners).
nix-shell -p treefmt deadnix alejandra actionlint beautysh biome yamlfmt taplo --run \
  'treefmt --config-file treefmt.ci.toml'

